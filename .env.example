# xAI Grok API (used by xai_cli.py) — preferred for most queries, especially search (cheaper)
XAI_API_KEY=

# Google Gemini API (used by gemini_cli.py) — use for long context + deeper/less biased analysis
GEMINI_API_KEY=

# Cloudflare — used by wrangler CLI, the three Cloudflare MCP servers (docs/bindings/api),
# and Chrome MCP automation of dash.cloudflare.com. See .claude/skills/using-cloudflare-primitives.md.
# Account ID is the 32-char hex visible in any dashboard URL: https://dash.cloudflare.com/<account_id>/...
CLOUDFLARE_ACCOUNT_ID=
# API token: cloudflare.com → My Profile → API Tokens → Create Token. Scope to what you actually need
# (Workers Edit, R2 R/W, DNS Edit, AI Gateway Read, etc.). DO NOT use the global API key — it can't be scoped.
CLOUDFLARE_API_TOKEN=
# Zone ID: only needed when scripting against a specific zone (DNS, WAF, Page Rules). One per zone;
# find it under the zone's Overview page in the dashboard sidebar.
CLOUDFLARE_ZONE_ID=

# Clerk — auth/user-management. Used by @clerk/* SDKs, the Clerk MCP server (mcp__clerk__*),
# and Chrome MCP automation of dashboard.clerk.com. See .claude/skills/using-clerk.md.
# Grab keys: dashboard.clerk.com → instance → API keys (the page emits the right env-var prefix per framework).
# Publishable key: safe to embed in client code. Prefix varies by framework — NEXT_PUBLIC_ for Next.js,
# VITE_ for Vite, EXPO_PUBLIC_ for Expo, PUBLIC_ for Astro, none for vanilla/server. pk_test_* = dev, pk_live_* = prod.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Secret key: backend ONLY. Grants admin-level access to the Clerk Backend API (impersonate users, change
# security settings, create admin users). NEVER ship to the client or any NEXT_PUBLIC_/VITE_/EXPO_PUBLIC_ var.
CLERK_SECRET_KEY=
# Webhook signing secret: only when consuming Clerk webhooks (Svix-format). Required for signature
# verification — without it, anyone who finds your webhook URL can forge events into your DB.
CLERK_WEBHOOK_SIGNING_SECRET=
# JWT key / issuer: only when verifying Clerk-issued JWTs in a non-Clerk backend (e.g. Go, Python, Rust).
# Frontend Next/React code uses auth() / useAuth() and doesn't need this.
CLERK_JWT_KEY=
